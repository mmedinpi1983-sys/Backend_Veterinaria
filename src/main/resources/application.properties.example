# ============================================================
#  Plantilla de configuracion - VetClinic API (proyecto integrado)
#  Copia este archivo como  application.properties  y ajusta tu SQL Server.
# ============================================================
spring.application.name=api-veterianria

# El frontend de main apunta a este puerto
server.port=8080

# SQL Server
spring.datasource.url=jdbc:sqlserver://localhost:1433;databaseName=DBVet;encrypt=false;trustServerCertificate=true
spring.datasource.username=sa
spring.datasource.password=TU_PASSWORD_AQUI
spring.datasource.driver-class-name=com.microsoft.sqlserver.jdbc.SQLServerDriver

# JPA / Hibernate (el esquema ya existe)
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.SQLServerDialect

# JWT (secret de 32+ caracteres)
jwt.secret=clave-secreta-vetclinic-integrado-cambia-esto-1234567890
jwt.expiration=86400000

# Logs: la configuracion del archivo logs/app.log esta en logback-spring.xml.
# (Alternativa mas simple que mostro el profe, si NO usaras logback-spring.xml:)
#   logging.file.name=logs/app.log
#   logging.logback.rollingpolicy.max-file-size=20KB
